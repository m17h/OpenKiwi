{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenKiwi",
  "version": "0.4.3",
  "identifier": "com.kiwi.harness",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenKiwi",
        "width": 1380,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "OpenKiwi, a transparent AI coding harness"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREMjg0NDc1QTlCN0Q0OEYKUldTUDFMZXBkVVFvM1NHa21BajdjbXN5ZStISEhIeWlEbW00NDN2VHZCWmZjc3FpTmNwWG81UHQK",
      "endpoints": [
        "https://github.com/m17h/OpenKiwi/releases/latest/download/latest.json"
      ]
    }
  }
}
