{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenKiwi",
  "version": "0.1.0",
  "identifier": "com.kiwi.harness",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenKiwi",
        "width": 1380,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "OpenKiwi, a transparent AI coding harness"
  }
}
